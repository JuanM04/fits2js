{
  "name": "fits2js",
  "type": "module",
  "version": "0.0.5",
  "packageManager": "pnpm@10.26.2",
  "description": "Read and write FITS files anywhere",
  "author": "Juan Martín Seery <me@juanm04.com>",
  "license": "MIT",
  "homepage": "https://github.com/JuanM04/fits2js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JuanM04/fits2js.git"
  },
  "bugs": "https://github.com/JuanM04/fits2js/issues",
  "keywords": [],
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "prepublishOnly": "pnpm run build",
    "release": "bumpp && pnpm publish",
    "start": "tsx src/index.ts",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^6.7.3",
    "@types/node": "^24.10.4",
    "bumpp": "^10.3.2",
    "eslint": "^9.39.2",
    "publint": "^0.3.16",
    "tinyexec": "^1.0.2",
    "tsdown": "^0.18.4",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.0",
    "vitest": "^4.0.16",
    "vitest-package-exports": "^1.1.1",
    "yaml": "^2.8.2"
  }
}
